# Copy this file to config/domain-onboard.env and fill in values.

# Cloudflare API token with Zone:Read + DNS:Edit on the target zone.
CLOUDFLARE_API_TOKEN=

# Root zone, no trailing dot.
CF_ZONE_NAME=newpsychonaut.com

# Host label relative to the zone.
# Example: "www.neurophenomai" -> www.neurophenomai.newpsychonaut.com
SUBDOMAIN_HOST=www.neurophenomai

# Azure default hostname for the target Web App.
AZURE_WEBAPP_HOSTNAME=neurophenom-exeterai-bjjgnkmj25upk.azurewebsites.net

# Azure Custom Domain Verification ID value from Web App -> Custom domains.
AZURE_VERIFICATION_ID=

# DNS behavior
CF_PROXIED=false
CF_TTL=120

# Optional Azure helpers
AZURE_WEBAPP_NAME=neurophenom-exeterai-bjjgnkmj25upk
AZURE_RESOURCE_GROUP=rg-exeterai-migration

# Optional propagation poll tuning
DIG_RETRIES=12
DIG_SLEEP_SECONDS=10
