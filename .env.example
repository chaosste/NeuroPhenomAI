# NeuroPhenom AI — server environment (copy to .env for local production runs)
# The React app does NOT read these for Gemini. Users paste a Gemini key in Settings (BYOK).

# HTTP port for `npm start` (Express serving dist/ + /api/*)
PORT=8080

# Optional: Azure OpenAI / Foundry (used by server.js /api/welcome and /api/analyze)
# The UI currently uses client-side Gemini; these enable the server-mediated path.
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=YOUR_DEPLOYMENT_NAME
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional rate limits (requests per 15-minute window)
WELCOME_RATE_LIMIT_MAX=40
ANALYZE_RATE_LIMIT_MAX=20
STATIC_RATE_LIMIT_MAX=300
